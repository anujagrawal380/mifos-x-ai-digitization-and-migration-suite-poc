# --- LLM Backend ---
# Options: "groq" | "gemini" | "ollama"
LLM_BACKEND=groq

# --- Groq (recommended — free tier: 30 req/min, 14,400/day, vision support) ---
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_key_here

# --- Gemini (free tier: 15 req/min — requires fresh project at aistudio.google.com) ---
GEMINI_API_KEY=your_key_here

# --- Ollama (fully local, no API key needed) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision

# --- Fineract API ---
FINERACT_BASE_URL=https://localhost:8443/fineract-provider/api/v1
FINERACT_USERNAME=mifos
FINERACT_PASSWORD=password
FINERACT_TENANT=default
# Set to false if using self-signed cert (local Docker)
FINERACT_VERIFY_SSL=false
